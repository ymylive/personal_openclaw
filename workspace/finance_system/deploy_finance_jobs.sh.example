#!/usr/bin/env bash
set -euo pipefail

OPENCLAW_CONTAINER="${OPENCLAW_CONTAINER:-openclaw-gateway}"
OPENCLAW_HOME="${OPENCLAW_HOME:-/home/node/.openclaw}"
WORKSPACE_DIR="${WORKSPACE_DIR:-/home/node/.openclaw/workspace}"
PYTHON_BIN="${PYTHON_BIN:-python3}"
CRON_OUTPUT="${CRON_OUTPUT:-finance_system/openclaw_schedule.cron}"
FINANCE_DASHBOARD_SECRET="${FINANCE_DASHBOARD_SECRET:-CHANGE_ME}"
FINANCE_DASHBOARD_PUBLIC_BASE_URL="${FINANCE_DASHBOARD_PUBLIC_BASE_URL:-https://cornna.qzz.io}"
FINANCE_DASHBOARD_PORT="${FINANCE_DASHBOARD_PORT:-18790}"

cd "$(dirname "$0")/.."

echo "[1/5] Check current Telegram stream mode"
openclaw config get channels.telegram.streamMode || true

echo "[2/5] Force Telegram final-only replies"
openclaw config set channels.telegram.streamMode off
openclaw config get channels.telegram.streamMode

echo "[3/5] Runtime verification"
FINANCE_DASHBOARD_SECRET="$FINANCE_DASHBOARD_SECRET" \
FINANCE_DASHBOARD_PUBLIC_BASE_URL="$FINANCE_DASHBOARD_PUBLIC_BASE_URL" \
FINANCE_DASHBOARD_PORT="$FINANCE_DASHBOARD_PORT" \
python finance_system/check_openclaw_runtime.py \
  --openclaw-home "$OPENCLAW_HOME" \
  --workspace-dir "$WORKSPACE_DIR" \
  --json

echo "[4/5] Render cron"
python finance_system/render_schedule_cron.py \
  --container "$OPENCLAW_CONTAINER" \
  --openclaw-home "$OPENCLAW_HOME" \
  --workspace-dir "$WORKSPACE_DIR" \
  --python-bin "$PYTHON_BIN" \
  --output "$CRON_OUTPUT"
cat "$CRON_OUTPUT"

echo "[5/5] Install cron"
crontab "$CRON_OUTPUT"
crontab -l

cat <<EOF

Dashboard sidecar next steps:
1. export FINANCE_DASHBOARD_SECRET="$FINANCE_DASHBOARD_SECRET"
2. export FINANCE_DASHBOARD_PUBLIC_BASE_URL="$FINANCE_DASHBOARD_PUBLIC_BASE_URL"
3. cp finance_system/openclaw_finance_dashboard.service.example /etc/systemd/system/openclaw-finance-dashboard.service
4. systemctl daemon-reload
5. systemctl enable --now openclaw-finance-dashboard.service
6. systemctl status openclaw-finance-dashboard.service --no-pager
EOF
