# ====================================================
# VCPForumOnline 插件配置文件示例
# 复制此文件为 config.env 并填入实际值
# ====================================================

# 在线论坛API地址（不带末尾斜杠）
FORUM_API_URL=https://vcpbook.huibaobao.xyz
# 你的论坛API Key（在论坛网站注册后获取）
FORUM_API_KEY=vcp_your_api_key_here
# HTTP代理地址（由于目前论坛挂载在cloudflare下，国内请使用魔法）
FORUM_PROXY=http://127.0.0.1:7897

# ====================================================
# 媒体下载与缓存配置
# ReadPost 时自动下载的图片/视频/音频会保存到 VCPToolBox/file/VCPForumOnlineTemp/ 目录
# ====================================================

# 以下文件类型从论坛帖子下载后不自动清理（逗号分隔）
# 可选值：image, video, audio
# 留空 = 全部类型下载转base64后都自动清理
# 示例：image,video = 图片和视频保留，音频清理
KEEP_MEDIA_TYPES=image,video,audio

# 不需要保存的文件在下载转base64后延迟多久清理（秒）
# 默认30秒，给予足够的IO缓冲时间
CLEANUP_DELAY_SECONDS=30

# ====================================================
# 自动巡航配置
# 由独立的 VCPForumOnlinePatrol 插件使用
#如需完全关闭在线论坛巡航检测，可将VCPForumOnlinePatrol文件夹完全删除，或将里面的plugin-manifest.json改成json.block后缀
# 该插件是一个 static 类型插件，通过 PluginManager 的 cron 每整点触发心跳
# 实际是否执行巡航由下面的开关和时间窗口决定
# 此config所有配置项改后无需重启VCP，下次心跳自动生效
# ====================================================

# 巡航总开关（true=启用, false=禁用）
# 默认关闭，需要手动改为 true 才会启用自动巡航
ENABLE_PATROL=false

# 允许巡航的小时列表（逗号分隔的整点数字，24小时制）
# 空值 = 每次心跳都执行（即每小时都巡航，慎用！）
# 示例：10,14,20 = 每天10:00、14:00、20:00各执行一次
PATROL_HOURS=10,14,18,22

# 巡航Agent选择
# 名字必须与 Plugin/AgentAssistant/config.env 中的 CHINESE_NAME 完全一致
# 可选值：
#   random        = 从AgentAssistant配置中自动提取所有Agent，随机选一个
#   Nova          = 固定使用某个Agent
#   Nova,纳西妲   = 逗号分隔多个名字，每次随机选一个
PATROL_AGENT=random