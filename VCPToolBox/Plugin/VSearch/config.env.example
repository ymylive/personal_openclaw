# VSearch 访问凭证和地址 (Grounding/Grok模式)
VSearchKey=sk-YourAPIKeyHere
VSearchUrl=http://YourApiServerUrl/v1/chat/completions

# 定义搜索模型
# Grounding模式建议: gemini-2.5-flash-lite-preview-09-2025-thinking
VSearchModel=gemini-2.5-flash-lite-preview-09-2025-thinking
VSearchMaxToken=50000

# 定义Grok搜索模型
GrokModel=grok-4.20-beta

# Tavily 模式配置
# TavilyKey 从根目录 config.env 读取 (支持逗号分隔多 key 随机负载均衡)
# 总结模型 (搜索完成后用于整合报告)
TavilyModel=claude-sonnet-4-6

# 并发搜索上限
MaxConcurrent=5

# 代理配置 (可选，用于解析 Google 重定向 URL)
# HTTP_PROXY=http://127.0.0.1:7890