# ============================================
# ComfyCloudGen 配置文件
# ============================================
# 复制此文件为 config.env 并填写你的凭证：
#   cp config.env.example config.env
#
# 推荐使用一键认证脚本自动填写 Firebase 凭证：
#   node setup.js  (或 setup.bat)
# ============================================

# ------ HTTP 代理（国内必需） ------
# Comfy Cloud 和 Google 认证服务均需要代理访问
# 填写你的本地代理地址，例如 Clash / v2rayN / SSR 等
COMFY_PROXY=http://127.0.0.1:7890

# ------ Firebase 认证凭证 ------
# 以下两项由 setup.js 自动提取并写入，无需手动填写
# 如需手动获取：登录 cloud.comfy.org → F12 → Application → Local Storage
#   → 找到 firebase:authUser:xxx 条目
#   → refreshToken 在 stsTokenManager.refreshToken
#   → apiKey 在 key 名的第三段 (firebase:authUser:{API_KEY}:[DEFAULT])

COMFY_REFRESH_TOKEN=
COMFY_FIREBASE_API_KEY=

# ------ 可选配置 ------

# 工作流缓存上限（FIFO 淘汰），默认 10
# COMFY_CACHE_MAX=10