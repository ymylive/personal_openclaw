# JapaneseHelper 可选配置（v2.14.0 推荐模板）

# ================= 基础 =================
REQUEST_TIMEOUT=10
JISHO_API_ENABLED=true
SUDACHI_SPLIT_MODE=C
USER_LEXICON_PATH=./user_lexicon.json
DOMAIN_LEXICON_PATH=./domain_lexicon.json
ENABLE_ADAPTIVE_SESSION=true


# ================= 在线词典 =================
# race=谁快用谁；aggregate=聚合结果
ONLINE_DICT_MODE=race
ONLINE_DICT_TIMEOUT=1.2
ONLINE_DICT_GLOBAL_TIMEOUT=2.5
ONLINE_DICT_RETRY=1
ONLINE_CACHE_TTL_SEC=86400
ONLINE_PROVIDER_ORDER=jisho,jotoba
JOTOBA_API_ENABLED=false

# ===== P0 稳定性参数 =====
ONLINE_CACHE_MAX_ITEMS=2000
ONLINE_CACHE_FLUSH_INTERVAL_SEC=2.0
ONLINE_CACHE_STALE_IF_ERROR_SEC=600
ONLINE_CACHE_LOCK_TIMEOUT_SEC=2.0
ONLINE_DICT_BACKOFF_BASE_SEC=0.15
ONLINE_DICT_BACKOFF_MAX_SEC=1.2
ONLINE_PROVIDER_CB_FAIL_THRESHOLD=3
ONLINE_PROVIDER_CB_COOLDOWN_SEC=20
ONLINE_PROVIDER_CB_HALFOPEN_PROB=0.25
ONLINE_PROVIDER_STATE_FLUSH_INTERVAL_SEC=1.0
OBSERVABILITY_LOG_PATH=./observability.log

# ================= Full SQLite Dictionary =================
# 主开关：启用 full_db_integration.py
FULL_DB_ENABLED=true
# 主词典库（JMdict / KANJIDIC2 / Wadoku / Grammar / OJAD / JLPT 都可放同一库）
JMDICT_FULL_DB_PATH=./data/db/jdict_full.sqlite
KANJIDIC_FULL_DB_PATH=./data/db/jdict_full.sqlite
FULL_DB_SQLITE_TIMEOUT=2.0

# 扩展库开关（runtime）
GRAMMAR_FULL_DB_ENABLED=true
WADOKU_DB_ENABLED=true
OJAD_DB_ENABLED=true

# 扩展库路径（通常与主库同路径）
GRAMMAR_FULL_DB_PATH=./data/db/jdict_full.sqlite
WADOKU_DB_PATH=./data/db/jdict_full.sqlite
OJAD_DB_PATH=./data/db/jdict_full.sqlite

# OJAD 在线接口（留空=禁用，仅用本地 ojad_pitch）
OJAD_API_ENDPOINT=
OJAD_TIMEOUT_SEC=1.8

# ================= 兼容旧参数（保留） =================
# 部分旧版本会读取以下变量；建议保留，避免升级回退问题
GRAMMAR_DB_PATH=./grammar_explainers_ext.json
PITCH_ACCENT_EXT_PATH=./pitch_accent_ext.json

# Phase 5.1 structured defaults (optional)
STRUCTURED_DEFAULT_COMPACT=false
READING_AID_COMPACT_TOKENS_DEFAULT=false
PARSE_TREE_INCLUDE_MERMAID_DEFAULT=true
SCHEMA_PROBE_ENABLED=true
FULL_DB_LEXICON_LOOKUP_ENABLED=true
JLPT_DB_TIMEOUT_SEC=0.35
JLPT_DB_CACHE_MAX=4096

